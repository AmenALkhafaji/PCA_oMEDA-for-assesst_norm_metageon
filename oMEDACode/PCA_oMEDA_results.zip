%% ANOVA comparison of normalization methods
% This scripts requires the .mat files generated by pca_omeda_analysis.m

clear; close all; clc;

% Load error values (change file name and prefix to the desired scenario)
load results_genus_unbalanced.mat
file_prefix = "genus_unbalanced";

% Path to figures folder
saveDir = "ANOVA_results/" + file_prefix + "/";
if ~exist(saveDir, 'dir')
    mkdir(saveDir);
end
savePath = saveDir + file_prefix;

% Make 'raw counts' the first column
methodNames(methodNames == 'RAREFY') = 'Rarefaction';
raw_id = find(methodNames == 'counts');
methodNames = ["Raw data", methodNames(1:raw_id-1), methodNames(raw_id+1:end)];
cols = setdiff(1:size(eLow, 2), raw_id);

eLow = eLow(:, [raw_id, cols]);
eHigh = eHigh(:, [raw_id, cols]);
eFull = eFull(:, [raw_id, cols]);

% Join all depth strata
eAll(:,:,1) = eLow;
eAll(:,:,2) = eHigh;
eAll(:,:,3) = eFull;

%% Perform two-way ANOVA
normMethods = repelem(methodNames, size(eLow, 1));  % normalization method labels
repetitions = repmat(1:100, 1, size(eLow, 2));  % repetition labels
factors = {normMethods, repetitions};

aovLow = anova(factors, eLow(:), FactorNames=["Norm. method", "Repetition"]);  % Low depth
aovHigh = anova(factors, eHigh(:), FactorNames=["Norm. method", "Repetition"]);   % High depth
aovFull = anova(factors, eFull(:), FactorNames=["Norm. method", "Repetition"]);   % Full dataset

tableLow = stats(aovLow);
tableHigh = stats(aovHigh);
tableFull = stats(aovFull);

normMethodsAll = repmat(repelem(methodNames, size(eAll, 1)), 1, size(eAll, 3));  % normalization method labels
repetitionsAll = repmat(1:100, 1, size(eAll, 2)*size(eAll, 3));  % repetition labels
depthLabelsAll = repelem({'Low depth', 'High depth', 'Full dataset'}, size(eAll, 1)*size(eAll, 2));  % depth strata labels (low, high, full)
factorsAll = {normMethodsAll, depthLabelsAll, repetitionsAll};

% 3-way ANOVA model
aovAll = anova(factorsAll, eAll(:), FactorNames=["Norm. method", "Depth stratum", "Repetition"]);
tableAll = stats(aovAll);

% Add new column: Percentage of Sum of Squares
function tab = percent_ss(anova_tab)
    % Calculate %SS column
    sum_sq = anova_tab.SumOfSquares;
    tab = anova_tab;
    total_val = sum_sq(end);
    percent_values = (sum_sq ./ total_val) * 100;
    percent_values(end) = sum(percent_values(1:end-1));
    tab.PercentSumOfSquares = percent_values;
    tab = movevars(tab, 'PercentSumOfSquares', 'After', 'SumOfSquares');
end
tableLow = percent_ss(tableLow);
tableHigh = percent_ss(tableHigh);
tableFull = percent_ss(tableFull);
tableAll = percent_ss(tableAll);

% Display ANOVA results
disp('--- ANOVA Results for Low Depth ---');
disp(tableLow);
disp('--- ANOVA Results for High Depth ---');
disp(tableHigh);
disp('--- ANOVA Results for Full Dataset ---');
disp(tableFull);
disp('--- ANOVA Results for All ---');
disp(tableAll);

%% Assumption check

models = {aovLow, aovHigh, aovFull, aovAll};
modelNames = {'Low depth'; 'High depth'; 'Full dataset'; 'All'};

nModels = numel(models);
res = cell(nModels, 1);
labels = cell(nModels, 1);
Skewness = zeros(nModels, 1);
Kurtosis = zeros(nModels, 1);

for i=1:nModels
    res{i} = table2array(models{i}.Residuals(:, 1)); % raw residuals
    labels{i} = table2array(models{i}.Factors);
    Skewness(i) = skewness(res{i}, 0);  % skewness should be close to 0
    Kurtosis(i) = kurtosis(res{i}, 0);  % kurtosis should be close to 3
end

% Table of skewness and kurtosis
normTable = table(modelNames, Skewness, Kurtosis);

% Q-Q plot
figure;
for i=1:nModels-1
    subplot(1,nModels-1,i);
    normplot(res{i});
    title(modelNames{i});
end
savefig(gcf, savePath + "_qqplot.fig");
exportgraphics(gcf, savePath + "_qqplot.png", 'Resolution',600);

% Homoscedasticity of residuals
figure;
for i=1:nModels-1
    subplot(2,nModels-1,i);
    boxplot(res{i}, labels{i}(:, 1));
    title(modelNames{i});
    xlabel("Normalization method");
    ylabel("Residuals");
    
    subplot(2,nModels-1,i+nModels-1);
    boxplot(res{i}, labels{i}(:, 2));
    xticks(0:10:100);
    xticklabels(0:10:100);
    xlabel("Repetition");
    ylabel("Residuals");
end

savefig(gcf, savePath + "_homoscedasticity.fig");
exportgraphics(gcf, savePath + "_homoscedasticity.png", 'Resolution',600);

%% Assumption check for 3-way model

res = table2array(aovAll.Residuals(:, 1)); % raw residuals
labels = table2array(aovAll.Factors);

% Q-Q Plot
figure;
normplot(res);
title('Q-Q Plot of Residuals');
savefig(gcf, savePath + "_qqplot_all.fig");
exportgraphics(gcf, savePath + "_qqplot_all.png", 'Resolution', 600);

% Homoscedasticity of Residuals
figure;
% Factor 1
subplot(1, 3, 1);
boxplot(res, labels(:, 1));
xlabel("Normalization method");
ylabel("Residuals");

% Factor 2
subplot(1, 3, 2);
boxplot(res, labels(:, 2));
xlabel("Depth stratum");
ylabel("Residuals");

% Factor 3
subplot(1, 3, 3);
boxplot(res, labels(:, 3));
xticks(0:10:100);
xticklabels(0:10:100);
xlabel("Repetition");
ylabel("Residuals");

savefig(gcf, savePath + "_homoscedasticity_all.fig");
exportgraphics(gcf, savePath + "_homoscedasticity_all.png", 'Resolution', 600);


%% Post-hoc tests (pairwise comparisons)
multLow = multcompare(aovLow, aovLow.FactorNames(1), Alpha=0.05);
multHigh = multcompare(aovHigh, aovHigh.FactorNames(1), Alpha=0.05);
multFull = multcompare(aovFull, aovFull.FactorNames(1), Alpha=0.05);
multAll = multcompare(aovAll, aovAll.FactorNames(1), Alpha=0.05);

% Plot comparisons
figure;
subplot(3,1,1);
title("Low depth");
plotComparisons(aovLow, aovLow.FactorNames(1), Alpha=0.05);
subplot(3,1,2);
title("High depth");
plotComparisons(aovHigh, aovHigh.FactorNames(1), Alpha=0.05);
subplot(3,1,3);
title("Full dataset");
plotComparisons(aovFull, aovFull.FactorNames(1), Alpha=0.05);

savefig(gcf, savePath + "_posthoc.fig");
exportgraphics(gcf, savePath + "_posthoc.png", 'Resolution',600);

figure;
title("Post-hoc comparisons")
plotComparisons(aovAll, aovAll.FactorNames(1), Alpha=0.05);

savefig(gcf, savePath + "_posthoc_all.fig");
exportgraphics(gcf, savePath + "_posthoc_all.png", 'Resolution',600);

%% Compact Letter Display to summarize multcompare plots in a table

function resultTable = get_cld_ordered(T, groupMeans, alpha)
    % T: Table with columns 'Group1', 'Group2', and 'pValue'
    % groupMeans: A table or struct containing {Group, Mean, Std}
    % alpha: Significance level (default 0.05)
    
    if nargin < 3, alpha = 0.05; end
    
    % Sort groups by mean
    [sortedMeans, sortIdx] = sort(groupMeans.Mean);
    sortedGroups = groupMeans.Group(sortIdx);
    sortedStds = groupMeans.StD(sortIdx);
    n = length(sortedGroups);
    
    % Create adjacency matrix (1 if NO significant difference)
    adj = eye(n); 
    for i = 1:size(T, 1)
        idx1 = find(strcmp(sortedGroups, T.Group1{i}));
        idx2 = find(strcmp(sortedGroups, T.Group2{i}));
        
        if ~isempty(idx1) && ~isempty(idx2) && T.pValue(i) >= alpha
            adj(idx1, idx2) = 1;
            adj(idx2, idx1) = 1;
        end
    end
    
    % Find overlapping nlocks
    % A letter represents a set of groups that are NOT significantly different
    cliques = {};
    for i = 1:n
        for j = n:-1:i
            % Check if all groups from i to j are mutually non-significant
            % This ensures the letters follow the mean order correctly
            subMatrix = adj(i:j, i:j);
            if all(subMatrix(:) == 1)
                current_clique = i:j;
                
                % Only add if this block is not contained in a previous one
                is_subset = false;
                for k = 1:length(cliques)
                    if all(ismember(current_clique, cliques{k}))
                        is_subset = true; 
                        break;
                    end
                end
                
                if ~is_subset
                    cliques{end+1} = current_clique;
                end
                break; % Found the largest block starting at i
            end
        end
    end
    
    % Assign letters
    letters = cell(n, 1);
    [letters{:}] = deal(''); 
    
    for j = 1:length(cliques)
        current_letter = char(96 + j); % 'a', 'b', etc.
        for member_idx = cliques{j}
            letters{member_idx} = [letters{member_idx}, current_letter];
        end
    end
    
    % Format final output table
    resultTable = table(sortedGroups, sortedMeans, sortedStds, letters, ...
                  'VariableNames', {'Group', 'Mean', 'StD', 'CLD'});
end

% Group means to order letters
meansLow = table(methodNames', mean(eLow, 1)', std(eLow, 1)', 'VariableNames', {'Group', 'Mean', 'StD'});
meansHigh = table(methodNames', mean(eHigh, 1)', std(eHigh, 1)', 'VariableNames', {'Group', 'Mean', 'StD'});
meansFull = table(methodNames', mean(eFull, 1)', std(eFull, 1)', 'VariableNames', {'Group', 'Mean', 'StD'});
tempData = reshape(permute(eAll, [1, 3, 2]), [], size(eAll, 2));
meansAll = table(methodNames', mean(tempData, 1)', std(tempData, 0, 1)', 'VariableNames', {'Group', 'Mean', 'StD'});

% Maximum p-value to consider groups significantly different
significance = 0.01; 

% Compact Letter Display (CLD)
% Tables include mean and std pca-omeda error and CLD letter for each group
cldLow = get_cld_ordered(multLow, meansLow, significance);
cldHigh = get_cld_ordered(multHigh, meansHigh, significance);
cldFull = get_cld_ordered(multFull, meansFull, significance);
cldAll = get_cld_ordered(multAll, meansAll, significance);

% Display results
disp("--- CLD Low depth ---");
disp(cldLow);
disp("--- CLD High depth ---");
disp(cldHigh);
disp("--- CLD Full dataset ---");
disp(cldFull);
disp("--- CLD All ---");
disp(cldAll);

%% Save ANOVA results and post-hoc comparisons
save(savePath + "_anova_results.mat", 'aovLow', 'aovHigh', 'aovFull', 'aovAll', ...
    'tableLow', 'tableHigh', 'tableFull', 'tableAll', 'normTable', ...
    'multLow', 'multHigh', 'multFull', 'multAll', ...
    'cldLow', 'cldHigh', 'cldFull', 'cldAll');
close all;